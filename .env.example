# Local/dev runtime values for Người 2 services.
# Copy to .env for local testing. Do not commit real secrets.

KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_REALM=zero-trust
KEYCLOAK_ISSUER=http://localhost:8080/realms/zero-trust
KEYCLOAK_JWKS_URL=http://localhost:8080/realms/zero-trust/protocol/openid-connect/certs
KEYCLOAK_AUDIENCE=demo-client

AUTHZ_HOST=0.0.0.0
AUTHZ_PORT=8090
AUTHZ_CONFIG_PATH=authz/config.yaml

OPA_URL=http://localhost:8181
OPA_DECISION_URL=http://localhost:8181/v1/data/zerotrust/authz/allow

REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

DPOP_REQUIRED=true
DPOP_PROOF_LIFETIME_SECONDS=300
DPOP_MAX_CLOCK_SKEW_SECONDS=60

LOG_LEVEL=INFO
